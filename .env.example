# ── gRPC Backend ─────────────────────────────────────────────────────────────
# ที่อยู่ของ gRPC server (Rust backend)
GRPC_HOST=localhost:50051

# Path ไปยัง proto directory (relative จาก production-traceback/ หรือ absolute path)
# ค่า default: ../gRPC/denso/proto  (เมื่อ bun dev รันจาก production-traceback/)
GRPC_PROTO_DIR=../gRPC/denso/proto

# ── Image Server ──────────────────────────────────────────────────────────────
# Base URL สำหรับรูปภาพพนักงาน (ใช้ใน orders/[id])
# ต้องขึ้นต้นด้วย PUBLIC_ เพื่อให้ browser อ่านได้
PUBLIC_EMP_IMAGE_BASE=http://<IMAGE_SERVER_IP>:<PORT>/emp_image_new
